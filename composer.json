{
    "name": "semitexa/ledger",
    "description": "Semitexa Ledger — SQLite append-only event ledger with NATS JetStream multi-node propagation",
    "type": "semitexa-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Semitexa",
            "email": "support@semitexa.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-sqlite3": "*",
        "semitexa/core": "*",
        "basis-company/nats": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Ledger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Ledger\\Tests\\": "tests/"
        }
    },
    "extra": {
        "semitexa-module": {
            "extends": null
        }
    },
    "keywords": [
        "semitexa",
        "ledger",
        "nats",
        "jetstream",
        "event-sourcing",
        "sqlite"
    ]
}
